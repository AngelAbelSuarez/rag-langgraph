# === API Keys ===
NVIDIA_API_KEY=nvapi-placeholder
LANGSMITH_API_KEY=ls-placeholder

# === Endpoints ===
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379

# === LangSmith ===
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=rag-langgraph

# === Models ===
EMBEDDING_MODEL=nvidia/nv-embedcode-7b-v1
GRADING_MODEL=nvidia/nemotron-mini-4b-instruct
GENERATION_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
RERANKING_MODEL=nvidia/nv-rerank-qa-mistral-4b:1
